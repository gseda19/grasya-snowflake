[sqlfluff]
templater = dbt
dialect = snowflake
rules = AL01, AL02, AL04, AL05, AL06, AL07, AL08, AL09,
        AM01, AM02, AM03, AM04, AM05, AM06,
        CP01, CP02, CP03, CP04, CP05,
        CV01, CV02, CV03, CV04, CV05, CV06, CV07, CV08, CV09, CV10, CV11,
        LT01, LT02, LT03, LT04, LT05, LT06, LT07, LT08, LT09, LT10, LT11, LT12, LT13,
        RF01, RF02, RF03, RF04, RF05, RF06,
        ST01, ST02, ST03, ST04, ST05, ST06, ST07, ST08, ST09, ST10, ST11
max_line_length = 120
indent_unit = space
tab_space_size = 4
 
[sqlfluff:templater:dbt]
project_dir = ./
 
[sqlfluff:indentation]
indent_unit = space
tab_space_size = 4
indented_joins = false
indented_ctes = false
indented_using_on = true